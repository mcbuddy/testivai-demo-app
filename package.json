{
  "name": "testivai-demo-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "update-baselines": "npx testivai compare --update-baselines",
    "compare": "npx testivai compare",
    "test:playwright": "playwright test examples/playwright",
    "test:webdriverio": "cd examples/webdriverio && npm install && npm test",
    "test:cypress": "cd examples/cypress && npm install && npm test",
    "test:selenium": "cd examples/selenium-python && python3 -m venv venv && source venv/bin/activate && pip install -r requirements.txt && pytest",
    "test:rspec": "cd examples/rspec-capybara && bundle install && bundle exec rspec",
    "test:selenium-java": "cd examples/selenium-java && mvn test",
    "test:cucumber-java": "cd examples/cucumber-java && mvn test"
  },
  "dependencies": {
    "@testivai/witness-cdp": "^0.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.53.1",
    "@testivai/witness-playwright": "^0.1.21",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "fs-extra": "^11.2.0",
    "globals": "^16.0.0",
    "playwright": "^1.53.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
