{
  "name": "testivai-demo-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "playwright test --config=playwright.oss.config.ts",
    "test:oss": "playwright test --config=playwright.oss.config.ts",
    "test:oss:headed": "playwright test --config=playwright.oss.config.ts --headed",
    "test:cloud": "playwright test",
    "test:cloud:ui": "playwright test --ui",
    "test:cloud:headed": "playwright test --headed",
    "test:cloud:debug": "playwright test --debug",
    "test:py": "pytest tests-py/ -q",
    "test:selenium:js": "node tests-selenium-js/visual.test.js && testivai report -q",
    "test:selenium:py": "pytest tests-selenium-py/ -q"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.53.1",
    "@testivai/witness": "^1.6.0",
    "@testivai/witness-playwright": "^1.5.1",
    "@testivai/witness-selenium": "^0.1.0",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "fs-extra": "^11.2.0",
    "globals": "^16.0.0",
    "playwright": "^1.53.1",
    "selenium-webdriver": "^4.46.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
  }
}
